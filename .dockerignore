# Root .dockerignore — applies to every image built with `context: .`
# (all Python services + the web image). Keep the context lean by excluding
# build artefacts and local junk, but DO NOT exclude source directories
# (ingest/, ai/, gateway/, scenarios/, shared/ …) — the service Dockerfiles
# COPY from them, so ignoring them breaks the build.

# Python / virtualenv
.venv/
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/*.egg-info/

# Node build artefacts (deps are reinstalled inside the image)
**/node_modules/

# VCS / local
.git/
.gitignore
*.log
.DS_Store

# Heavy data / media not needed by any build
data/clips/
data/fixtures/

# Local env files (never bake secrets into an image)
.env
.env.local

# Playwright outputs
**/playwright-report/
**/test-results/
