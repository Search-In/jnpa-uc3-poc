# ============================================================================
# JNPA UC-III PoC — AWS environment (EC2 config)
# Copy this file to `.env` on the EC2 instance and fill in credentials.
#   cp .env.aws.example .env
# All internal services run on Etc/UTC timezone.
# ============================================================================

# --- Postgres / TimescaleDB -------------------------------------------------
# Hardened password for the postgres container. Change this immediately!
POSTGRES_PASSWORD=change-me-postgres

# DSNs for services. We customize these so they match the POSTGRES_PASSWORD above.
# Other services on the internal jnpa network use the container host name "postgres".
POSTGRES_DSN=postgresql+asyncpg://postgres:change-me-postgres@postgres:5432/postgres
RFID_POSTGRES_DSN=postgresql://postgres:change-me-postgres@postgres:5432/postgres
TRUCK_POSTGRES_DSN=postgresql://postgres:change-me-postgres@postgres:5432/postgres
CONGESTION_POSTGRES_DSN=postgresql://postgres:change-me-postgres@postgres:5432/postgres
ANOMALY_POSTGRES_DSN=postgresql://postgres:change-me-postgres@postgres:5432/postgres

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Kafka ------------------------------------------------------------------
KAFKA_BROKERS=kafka:9092

# --- MQTT (Mosquitto) -------------------------------------------------------
MQTT_BROKER=mosquitto:1883

# --- MinIO (model artefacts + ANPR snapshots + driver reference photos) -----
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=change-me-minio-key
MINIO_SECRET_KEY=change-me-minio-secret
# The gateway's startup gate FAILS the boot if MinIO is unreachable (no base64
# fallback for reference photos). MinIO runs in-cluster on plain HTTP (minio:9000),
# so this MUST be false — setting it true makes the client speak TLS to a plaintext
# port and the boot dies with "[SSL: WRONG_VERSION_NUMBER]". Only set true if MinIO
# is actually fronted by TLS (e.g. via a sidecar/proxy with certs).
MINIO_SECURE=false
DRIVER_ENROL_BUCKET=drivers
# Browser-reachable S3 host used to MINT presigned driver-photo URLs. MinIO is
# not directly exposed; nginx reverse-proxies /minio/ -> minio:9000 (web/nginx/
# default.conf), so point this at the public domain + /minio sub-path. The
# gateway signs against the bare host and re-inserts /minio; nginx strips it
# before MinIO, so the SigV4 signature still matches. TLS terminates at nginx,
# so PUBLIC_SECURE is true even though in-cluster MINIO_SECURE stays false.
MINIO_PUBLIC_ENDPOINT=traffic-three.searchintech.in/minio
MINIO_PUBLIC_SECURE=true

# --- Grafana admin (SEC-4: no hard-coded creds; compose fails fast if unset) -
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana

# --- Gateway auth + RBAC (Wave 3 / SEC-1, SEC-2) ----------------------------
# Production-adjacent: enable auth, set a strong secret + scoped CORS origins.
# APP_ENV != development makes the gateway FAIL TO START unless AUTH_ENABLED=true,
# AUTH_JWT_SECRET is set to a non-default value, and AUTH_DEV_TOKENS=false.
APP_ENV=production
AUTH_ENABLED=true
# Belt-and-braces: production forces strict mode regardless, but set this false
# so no resilience fallback (in-memory store / base64 photo / synthetic identity)
# is ever taken. APP_ENV=production also engages the identity service's startup
# safety gate (ArcFace + liveness models MUST load or it refuses to start).
ALLOW_FALLBACK=false
# REQUIRED. The deploy workflow replaces this placeholder with `openssl rand
# -hex 32`. Never ship the literal placeholder — startup validation rejects it.
AUTH_JWT_SECRET=change-me-auth-secret
AUTH_RATE_LIMIT_PER_MIN=600
# Shared secret for trusted service-to-service calls (the scenarios-runner's
# scenario_step/routing/tas callbacks to the gateway). Both the gateway and the
# scenarios service read this same value; the deploy workflow backfills a random
# one if absent. The gateway accepts it via the X-Internal-Token header in place
# of a user JWT. Leave unset only in dev where AUTH_ENABLED=false.
INTERNAL_SERVICE_TOKEN=change-me-internal-token
# MUST be false outside development — the gateway refuses to start otherwise.
AUTH_DEV_TOKENS=false
# REQUIRED for the Driver PWA in production: gates POST /api/auth/device-token
# (which mints DRIVER-scoped tokens at pairing). Without it that route 404s and
# the PWA cannot authenticate. Inject the same value into the PWA build as
# VITE_PWA_PAIRING_SECRET. The seam where a real OTP / device-attestation flow
# replaces the shared secret post-award.
PWA_PAIRING_SECRET=change-me-pairing-secret
VITE_PWA_PAIRING_SECRET=change-me-pairing-secret
# PWA login eligibility gate. When true, POST /api/auth/device-token only mints a
# DRIVER token if the entered Vehicle ID is assigned to an ACTIVE driver
# (driver_enrollments -> drivers), else 403 "Vehicle is not assigned to an active
# driver". true for production/demo so unauthorized vehicles cannot pair; set
# false to allow any well-formed TRK-###### to pair (migration/testing only).
REQUIRE_DRIVER_PROFILE=true
# anpr-ingest: real YOLO detection + AI OCR. MUST be false in production — the
# ingest refuses to start with DRY_RUN=true outside development.
DRY_RUN=false
# Comma-separated allowed browser origins (set to your EC2 public origin(s)).
CORS_ALLOW_ORIGINS=
# DPDP: keep real-biometric processing OFF (post-award, consent-gated).
ALLOW_REAL_BIOMETRICS=false

# --- Identity / face-recognition (Appendix C #2) ----------------------------
# Production REQUIRES the real ArcFace embedder + anti-spoof liveness. With
# APP_ENV=production the identity service FAILS TO START unless both ONNX models
# load (fetch with scripts/fetch_face_model.sh -> ./data/models, mounted /models).
IDENTITY_EMBEDDER=onnx
IDENTITY_ARCFACE_MODEL=/models/arcface.onnx
IDENTITY_VERIFY_THRESHOLD=0.45
IDENTITY_PROVISIONAL_THRESHOLD=0.30
# Liveness MUST be on in production — a missing model is a hard boot failure, and
# any un-checked frame is REJECTED (no spoof may pass).
IDENTITY_LIVENESS=true
IDENTITY_LIVENESS_MODEL=/models/antispoof.onnx
IDENTITY_LIVENESS_THRESHOLD=0.5
IDENTITY_LIVENESS_REAL_INDEX=0

# --- External map / traffic / weather APIs ----------------------------------
# Optional: Set these to go live. Leaving them blank keeps simulation active.
GOOGLE_MAPS_API_KEY=
HERE_API_KEY=
TOMTOM_API_KEY=
OPENWEATHER_API_KEY=

# --- Indian Govt / vehicle data APIs ----------------------------------------
# Surepass (Vahan / FASTag / RC lookups)
SUREPASS_API_TOKEN=
# ULIP (Unified Logistics Interface Platform)
ULIP_API_KEY=
# --- FASTag ULIP APIs (/api/fastag/*) — CONFIGURE against the authorised provider.
# Empty FASTAG_ULIP_URL => the module returns a config error (500) and never calls
# a vendor. Paths + auth are env-driven (no hardcoded URL; do NOT assume bearer).
#   FASTAG_ULIP_AUTH_SCHEME: bearer | apikey | none   FASTAG_ULIP_AUTH_HEADER: X-API-Key
FASTAG_ULIP_URL=
FASTAG_ULIP_ENROUTE_PATH=
FASTAG_ULIP_BALANCE_PATH=
FASTAG_ULIP_TRANSACTION_PATH=
FASTAG_ULIP_AUTH_SCHEME=bearer
FASTAG_ULIP_AUTH_HEADER=X-API-Key
FASTAG_ULIP_TIMEOUT_S=10
FASTAG_ULIP_RETRIES=2
# ISRO Bhuvan geo-services
BHUVAN_API_KEY=

# --- Vahan simulator / live adapter -----------------------------------------
VAHAN_TOTAL_PLATES=25000
VAHAN_LATENCY_MEAN_MS=100
VAHAN_LATENCY_JITTER_MS=50

# --- ANPR + OCR inference service (ai/anpr) ---------------------------------
ANPR_DETECT_CONF=0.25
ANPR_EVAL_SIZE=200
ANPR_EVAL_TARGET_PCT=95.0
ANPR_YOLO_SHA256=
ANPR_MODEL_BUCKET=models

# --- Congestion forecaster (ai/congestion) ----------------------------------
CONGESTION_HISTORY_DAYS=14
CONGESTION_EPOCHS=50
CONGESTION_TARGET_F1=0.85
CONGESTION_TARGET_PRECISION=0.80
CONGESTION_TARGET_RECALL=0.80
CONGESTION_PREDICTIONS_TOPIC=traffic.predictions
CONGESTION_PUBLISH_INTERVAL_S=60

# --- Behavioural anomaly detector (ai/anomaly) ------------------------------
ANOMALY_ALERTS_TOPIC=alerts
ANOMALY_TRUCK_API_URL=http://truck-sim:8240
ANOMALY_WRONGWAY_DEG=120
ANOMALY_WRONGWAY_HOLD_S=2
ANOMALY_ABANDONED_S=120
ANOMALY_PARKING_S=300
ANOMALY_ROUTE_COSINE=0.4
ANOMALY_ROUTE_OFFROUTE_M=800
ANOMALY_ROUTE_HOLD_S=90
ANOMALY_AE_THRESHOLD_PCT=99
ANOMALY_EVIDENCE_BUCKET=evidence

# Public base for evidence URLs attached to alerts (MinIO S3 server).
# Replace <EC2_PUBLIC_IP> with the actual EC2 public IP or domain name.
ANOMALY_EVIDENCE_URL_BASE=http://<EC2_PUBLIC_IP>:9000/evidence

# --- Shared camera frame bus (ingest/anpr -> Redis Streams) -----------------
ANPR_PUBLISH_FRAMES=true
ANPR_FRAME_BUS_MAXLEN=600
ANPR_FRAME_JPEG_QUALITY=70

# --- API gateway + fallback orchestrator (gateway) --------------------------
GATEWAY_UPSTREAM_TIMEOUT_S=2.0
GATEWAY_ANPR_LAG_S=2.0
GATEWAY_CACHE_TTL_VAHAN_S=43200
GATEWAY_CACHE_TTL_ANPR_S=60
GATEWAY_PROVISIONAL_WINDOW_H=24
GATEWAY_GATE_BOOM_DELAY_S=5
GATEWAY_DECISION_RING_SIZE=1000
GATEWAY_TRUCK_SAMPLE=50

# WebPush (trucking-app PWA re-route notifications).
# Generate on the box with `make vapid-keys` or `python scripts/gen_vapid_keys.py`.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@jnpa-uc3.example

# Firebase Cloud Messaging (production push transport, added ALONGSIDE WebPush).
# Drop the Admin-SDK JSON in the host `secrets/` dir (mounted read-only into the
# gateway at /run/secrets/firebase; NEVER commit the key) and point the path at
# it. Blank disables FCM -> falls back to WebPush + WS.
FIREBASE_PROJECT_ID=jnpa3-e23e8
FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase/firebase-adminsdk.json
# Override the host dir mounted at /run/secrets/firebase (default ./secrets).
# FIREBASE_SECRETS_DIR=./secrets

# --- Trucking-App PWA (mobile-pwa, served at web :3000/pwa) ------------------
PWA_GATEWAY_URL=http://localhost:8000

# --- Control-room dashboard (web, port 3000) --------------------------------
# Mapbox style token for the dashboard's primary basemap (free tier OK).
# Leave blank to fallback to the Bhuvan (ISRO) WMS basemap.
MAPBOX_TOKEN=
VITE_BHUVAN_WMS=https://bhuvan-vec1.nrsc.gov.in/bhuvan/wms
# Dashboard data source. Production deploys MUST be `live` (real gateway /api).
# The web image build is refused if the bundle is not live (see web/Dockerfile).
VITE_DATA_MODE=live

# --- Corridor geometry ------------------------------------------------------
CORRIDOR_NAME=NH-348 JNPA to Karal Phata
PORT_LAT=18.9489
PORT_LON=72.9492
KARAL_LAT=18.78
KARAL_LON=73.08

# --- Observability ----------------------------------------------------------
TRACE_ID=aws-ec2-poc
