# ============================================================================
# JNPA UC-III PoC — local environment
# Copy this file to `.env.local` and fill in the API keys before `make up`.
#   cp .env.local.example .env.local
# Everything internal uses Etc/UTC; convert to Asia/Kolkata only at the
# dashboard layer.
# ============================================================================

# --- Postgres / TimescaleDB -------------------------------------------------
# Password is consumed by the postgres container (POSTGRES_PASSWORD) and must
# match the password embedded in POSTGRES_DSN below.
POSTGRES_PASSWORD=jnpa_pw
# DSN used by the shared package (SQLAlchemy + asyncpg). Host "postgres" is the
# compose service name used by other containers on the jnpa network.
# From the host machine use localhost:5433 (the published port; 5433 avoids
# clashing with a local Postgres on 5432). The bootstrap self-test does this
# rewrite for you.
POSTGRES_DSN=postgresql+asyncpg://postgres:jnpa_pw@postgres:5432/postgres

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Kafka ------------------------------------------------------------------
# Internal listener (service name). From the host use localhost:29092.
KAFKA_BROKERS=kafka:9092

# --- MQTT (Mosquitto) -------------------------------------------------------
MQTT_BROKER=mosquitto:1883

# --- MinIO (model artefacts + ANPR snapshots) -------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# --- External map / traffic / weather APIs ----------------------------------
# Google Maps Platform key — https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=
# HERE Maps freemium key — https://platform.here.com/
HERE_API_KEY=
# TomTom developer key — https://developer.tomtom.com/
TOMTOM_API_KEY=
# OpenWeather One Call key — https://openweathermap.org/api
OPENWEATHER_API_KEY=

# --- Indian Govt / vehicle data APIs ----------------------------------------
# Surepass (Vahan / FASTag / RC lookups) — https://surepass.io/
# Leave blank to keep the live adapter (vahan-live, port 8202) disabled: it
# returns HTTP 503 {"error":"live_disabled"} until a token is set. The
# simulator (vahan-sim, port 8201) needs no key.
SUREPASS_API_TOKEN=
# ULIP (Unified Logistics Interface Platform) — https://www.ulip.dpiit.gov.in/
ULIP_API_KEY=
# ISRO Bhuvan geo-services — https://bhuvan.nrsc.gov.in/
BHUVAN_API_KEY=

# --- Vahan simulator / live adapter -----------------------------------------
# Number of deterministic plates the simulator generates (default 25000).
VAHAN_TOTAL_PLATES=25000
# Artificial Parivahan-like latency per lookup (ms): mean +/- jitter.
VAHAN_LATENCY_MEAN_MS=100
VAHAN_LATENCY_JITTER_MS=50

# --- ANPR + OCR inference service (ai/anpr, port 8301) ----------------------
# YOLO detector confidence threshold.
ANPR_DETECT_CONF=0.25
# Held-out benchmark size (plates) and the combined-accuracy target for /eval.
ANPR_EVAL_SIZE=200
ANPR_EVAL_TARGET_PCT=95.0
# Expected SHA-256 of the YOLO plate weights; when set, startup hash-verifies
# the weights file and refuses to load on mismatch. Blank = check skipped.
ANPR_YOLO_SHA256=
# MinIO bucket the service persists/loads YOLO weights from.
ANPR_MODEL_BUCKET=models

# --- Congestion forecaster (ai/congestion, port 8311) -----------------------
# Days of synthetic bootstrap history + training epochs (first-boot training).
CONGESTION_HISTORY_DAYS=14
CONGESTION_EPOCHS=50
# Bid target gates; train.py exits non-zero if the held-out metrics miss these.
CONGESTION_TARGET_F1=0.85
CONGESTION_TARGET_PRECISION=0.80
CONGESTION_TARGET_RECALL=0.80
# Kafka topic the per-minute prediction scheduler publishes to.
CONGESTION_PREDICTIONS_TOPIC=traffic.predictions
CONGESTION_PUBLISH_INTERVAL_S=60

# --- Behavioural anomaly detector (ai/anomaly, port 8321) -------------------
# Hybrid: ByteTrack + rule engine + trajectory autoencoder. Consumes the shared
# Redis frame bus (frames.{camera_id}) + Kafka truck.telemetry; writes alerts to
# jnpa.alerts + Kafka "alerts" with MinIO evidence images.
ANOMALY_ALERTS_TOPIC=alerts
ANOMALY_TRUCK_API_URL=http://truck-sim:8240
# Rule thresholds (spec defaults).
ANOMALY_WRONGWAY_DEG=120
ANOMALY_WRONGWAY_HOLD_S=2
ANOMALY_ABANDONED_S=120
ANOMALY_PARKING_S=300
ANOMALY_ROUTE_COSINE=0.4
ANOMALY_ROUTE_OFFROUTE_M=800
ANOMALY_ROUTE_HOLD_S=90
ANOMALY_AE_THRESHOLD_PCT=99
ANOMALY_EVIDENCE_BUCKET=evidence
# Public base for evidence URLs attached to alerts (host-reachable MinIO S3 port).
ANOMALY_EVIDENCE_URL_BASE=http://localhost:9000/evidence

# --- Shared camera frame bus (ingest/anpr -> Redis Streams) -----------------
# ingest/anpr mirrors sampled jpeg frames to frames.{camera_id} for ai/anomaly.
ANPR_PUBLISH_FRAMES=true
ANPR_FRAME_BUS_MAXLEN=600
ANPR_FRAME_JPEG_QUALITY=70

# --- API gateway + fallback orchestrator (gateway, port 8000) ---------------
# The single public-facing service. Encodes the three fallback chains. Upstream
# URLs default to the jnpa service names; override only for unusual topologies.
# GATEWAY_VAHAN_LIVE_URL=http://vahan-live:8202
# GATEWAY_VAHAN_SIM_URL=http://vahan-sim:8201
# ULIP relay for the SECONDARY truck rung — empty uses a deterministic mock.
GATEWAY_ULIP_URL=
# Upstream call budget: >2 s lag means the ANPR feed is no longer "LIVE".
GATEWAY_UPSTREAM_TIMEOUT_S=2.0
GATEWAY_ANPR_LAG_S=2.0
# Cache TTLs (seconds): Vahan 12 h, ANPR frame window 60 s.
GATEWAY_CACHE_TTL_VAHAN_S=43200
GATEWAY_CACHE_TTL_ANPR_S=60
# Provisional admission cure window (hours) + elevated-scrutiny gate boom delay.
GATEWAY_PROVISIONAL_WINDOW_H=24
GATEWAY_GATE_BOOM_DELAY_S=5
# Decision ring buffer size (demo evidence) + 1-in-N truck-position WS sampling.
GATEWAY_DECISION_RING_SIZE=1000
GATEWAY_TRUCK_SAMPLE=50
# WebPush (trucking-app PWA re-route notifications). Generate with
# `make vapid-keys` (appends the keys here). Leave blank to run the demo on the
# WebSocket + in-app-polling fallback only — push is best-effort and optional.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@jnpa-uc3.example

# --- Trucking-App PWA (mobile-pwa, served at web :3000/pwa) ------------------
# Build-time gateway URL used by the PWA's Vite dev proxy only (the PWA always
# calls the relative /api path; nginx proxies it in the web image). The PWA is
# bundled into the web image and served at /pwa, so it shares the web origin.
PWA_GATEWAY_URL=http://localhost:8000

# --- Control-room dashboard (web, port 3000) --------------------------------
# Mapbox style token for the dashboard's primary basemap (free tier OK). Leave
# blank to use the Bhuvan (ISRO) WMS fallback basemap — the map renders either
# way. Passed to the web image as a Vite build arg (VITE_MAPBOX_TOKEN).
MAPBOX_TOKEN=
# Bhuvan (ISRO) WMS endpoint used as the fallback basemap provider.
VITE_BHUVAN_WMS=https://bhuvan-vec1.nrsc.gov.in/bhuvan/wms

# --- Corridor geometry ------------------------------------------------------
CORRIDOR_NAME=NH-348 JNPA to Karal Phata
PORT_LAT=18.9489
PORT_LON=72.9492
KARAL_LAT=18.78
KARAL_LON=73.08

# --- Observability ----------------------------------------------------------
# Optional trace id stamped onto every structured log line.
TRACE_ID=local-dev
