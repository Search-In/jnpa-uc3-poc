# ============================================================================
# JNPA UC-III PoC — PRODUCTION env (single-EC2 AWS deploy).
#
#   cp deploy/.env.prod.example .env.prod   # on the EC2 box
#   # then edit the secrets below and `deploy/jnpa-uc3.sh up`
#
# This is the .env.local.example values, hardened for a shared cloud host:
# real (non-default) passwords, the public URL, and demo-safe data posture.
# Anything not set here falls back to the defaults baked into docker-compose.yml.
# ============================================================================

# --- Public URL --------------------------------------------------------------
# The HTTPS origin the demo is served from (your domain behind the ALB / Caddy).
# Used to rewrite evidence-image URLs so they resolve from a browser, not from
# inside the container. NO trailing slash.
PUBLIC_BASE_URL=https://uc3.example.com

# --- Postgres / TimescaleDB --------------------------------------------------
# CHANGE THIS. Must match the password embedded in POSTGRES_DSN below.
POSTGRES_PASSWORD=__CHANGE_ME_strong_db_password__
POSTGRES_DSN=postgresql+asyncpg://postgres:__CHANGE_ME_strong_db_password__@postgres:5432/postgres

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Determinism / demo mode -------------------------------------------------
SEED=1337
# "mock" = offline-first, no external network calls (recommended for the demo).
DATA_MODE=mock
# OFFLINE=true forbids ALL network egress from simulators even if keys exist.
# Leave false unless you want to prove the network-disabled acceptance run.
OFFLINE=false
CLOUDEVENTS_ENABLED=true

# --- Kafka / MQTT ------------------------------------------------------------
KAFKA_BROKERS=kafka:9092
MQTT_BROKER=mosquitto:1883

# --- MinIO (model artefacts + ANPR snapshots) --------------------------------
# CHANGE THESE — they are the object-store root credentials.
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=__CHANGE_ME_minio_access_key__
MINIO_SECRET_KEY=__CHANGE_ME_strong_minio_secret__

# --- Grafana (admin login; console is localhost-only / SSH-tunnel) -----------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=__CHANGE_ME_grafana_password__

# --- External / Govt APIs (leave blank for the offline demo) -----------------
# Filling any of these in is what flips a feed from SIM to LIVE. The demo runs
# fully without them.
GOOGLE_MAPS_API_KEY=
HERE_API_KEY=
TOMTOM_API_KEY=
OPENWEATHER_API_KEY=
SUREPASS_API_TOKEN=
ULIP_API_KEY=
BHUVAN_API_KEY=

# --- Map basemap (dashboard) -------------------------------------------------
# Mapbox token (free tier OK). Blank -> Bhuvan (ISRO) WMS fallback basemap.
MAPBOX_TOKEN=
VITE_BHUVAN_WMS=https://bhuvan-vec1.nrsc.gov.in/bhuvan/wms

# --- Scale knobs (tune to the instance size) ---------------------------------
# On an 8 vCPU / 32 GB box the defaults (20k devices, scalable to 30k) hold.
# Drop these on a smaller instance to keep CPU headroom for the AI services.
VAHAN_TOTAL_PLATES=25000
TRUCK_NUM_DEVICES=20000
TRUCK_MAX_DEVICES=30000

# --- Corridor geometry -------------------------------------------------------
CORRIDOR_NAME=NH-348 JNPA to Karal Phata
PORT_LAT=18.9489
PORT_LON=72.9492
KARAL_LAT=18.78
KARAL_LON=73.08

# --- WebPush (trucking-app PWA re-route push; optional) ----------------------
# Generate with `make vapid-keys` (appends here). Blank -> push disabled, the
# PWA falls back to WebSocket + polling. The demo does not require push.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@jnpa-uc3.example
