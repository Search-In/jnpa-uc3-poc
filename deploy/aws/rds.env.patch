# =============================================================================
# JNPA UC-III — AWS RDS cutover: Postgres DSN overrides for .env.prod
# =============================================================================
# HOW TO USE (on the EC2 box, from the repo root):
#   1. Put the real RDS password in place of __RDS_PASSWORD__ below, e.g.:
#        sed -i 's/__RDS_PASSWORD__/YOUR_REAL_PASSWORD/g' deploy/aws/rds.env.patch
#      (URL-encode any of  : / ? # [ ] @  in the password before pasting.)
#   2. Append/override these lines into .env.prod, replacing the existing
#      POSTGRES_* / *_POSTGRES_DSN lines:
#        grep -vE '^(POSTGRES_PASSWORD|POSTGRES_DSN|RFID_POSTGRES_DSN|TRUCK_POSTGRES_DSN|CONGESTION_POSTGRES_DSN|ANOMALY_POSTGRES_DSN)=' .env.prod > .env.prod.tmp
#        cat deploy/aws/rds.env.patch >> .env.prod.tmp && mv .env.prod.tmp .env.prod
#   3. Verify: deploy/jnpa-uc3.sh config | grep -iE 'POSTGRES_DSN|sslmode|ssl='
#
# SSL NOTE (critical): the app engine calls create_async_engine(dsn) with NO
# connect_args (shared/jnpa_shared/db.py). asyncpg does NOT accept "sslmode";
# it needs "ssl". So the asyncpg URL uses ?ssl=require and the libpq URLs use
# ?sslmode=require. Do not "normalise" these to the same token.
# -----------------------------------------------------------------------------

# Kept so the (now-idle) postgres container still boots healthy; no service
# connects to it after cutover. Set to the RDS password for consistency.
POSTGRES_PASSWORD=__RDS_PASSWORD__

# asyncpg / SQLAlchemy async engine  (gateway + 7 other Python services)
POSTGRES_DSN=postgresql+asyncpg://postgres:__RDS_PASSWORD__@database-1.c5gg8y8cyk0z.ap-south-1.rds.amazonaws.com:5432/jnpa3?ssl=require

# libpq / psycopg DSNs (surface to services as POSTGRES_DSN_LIBPQ)
RFID_POSTGRES_DSN=postgresql://postgres:__RDS_PASSWORD__@database-1.c5gg8y8cyk0z.ap-south-1.rds.amazonaws.com:5432/jnpa3?sslmode=require
TRUCK_POSTGRES_DSN=postgresql://postgres:__RDS_PASSWORD__@database-1.c5gg8y8cyk0z.ap-south-1.rds.amazonaws.com:5432/jnpa3?sslmode=require
CONGESTION_POSTGRES_DSN=postgresql://postgres:__RDS_PASSWORD__@database-1.c5gg8y8cyk0z.ap-south-1.rds.amazonaws.com:5432/jnpa3?sslmode=require
ANOMALY_POSTGRES_DSN=postgresql://postgres:__RDS_PASSWORD__@database-1.c5gg8y8cyk0z.ap-south-1.rds.amazonaws.com:5432/jnpa3?sslmode=require
