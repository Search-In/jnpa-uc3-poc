# JNPA UC-III Trucking-App PWA — build/dev configuration (Vite).
# Copy to `.env` for `make dev-pwa`. The PWA always calls the relative /api path
# at runtime; these vars only affect the dev proxy + build base.

# Base path the app is served under. Must match where nginx mounts it in the web
# image (/pwa). Override to "/" only for a standalone-root deploy.
PWA_BASE=/pwa/

# Gateway URL used by the Vite dev proxy only (`make dev-pwa`). In the web image
# nginx proxies /api to the gateway, so the bundle never bakes this in.
PWA_GATEWAY_URL=http://localhost:8000

# Phone number the in-app SOS / Emergency button dials for the JNPA Port Control
# Room. Baked into the bundle at build time (Vite inlines VITE_*). Digits only,
# may include country code. Falls back to the national emergency number (112).
VITE_CONTROL_ROOM_PHONE=+912227244000

# --- Firebase (FCM push + Phone-Auth login) ---------------------------------
# ALL values here are PUBLIC (shipped in the client bundle) — safe to expose,
# exactly like the VAPID public key. The Firebase Admin *private* key stays
# server-side only (gateway env FIREBASE_SERVICE_ACCOUNT_PATH). Leave blank to
# run the PWA exactly as before on WebPush + WebSocket — every Firebase feature
# is gated on this config and cleanly no-ops when absent.
# Source: Firebase console -> Project settings -> General -> Your apps (Web
# config). VITE_FIREBASE_VAPID_KEY is OPTIONAL (Cloud Messaging -> Web Push
# certificates) — when blank the SDK uses FCM's default key and getToken still
# works. Real values for jnpa3-e23e8 go in .env.local (gitignored), not here.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=jnpa3-e23e8.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=jnpa3-e23e8
VITE_FIREBASE_STORAGE_BUCKET=jnpa3-e23e8.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
