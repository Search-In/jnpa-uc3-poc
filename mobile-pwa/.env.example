# JNPA UC-III Trucking-App PWA — build/dev configuration (Vite).
# Copy to `.env` for `make dev-pwa`. The PWA always calls the relative /api path
# at runtime; these vars only affect the dev proxy + build base.

# Base path the app is served under. Must match where nginx mounts it in the web
# image (/pwa). Override to "/" only for a standalone-root deploy.
PWA_BASE=/pwa/

# Gateway URL used by the Vite dev proxy only (`make dev-pwa`). In the web image
# nginx proxies /api to the gateway, so the bundle never bakes this in.
PWA_GATEWAY_URL=http://localhost:8000

# Phone number the in-app SOS / Emergency button dials for the JNPA Port Control
# Room. Baked into the bundle at build time (Vite inlines VITE_*). Digits only,
# may include country code. Falls back to the national emergency number (112).
VITE_CONTROL_ROOM_PHONE=+912227244000
