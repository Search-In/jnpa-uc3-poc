{
  "name": "jnpa-uc3-trucking-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "JNPA UC-III driver-side ETA / re-route advisory PWA (Prompt 11) — React + Vite + TS + vite-plugin-pwa",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3002",
