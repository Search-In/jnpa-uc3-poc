{
  "name": "jnpa-uc3-poc",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "format": "prettier --write \"web/src/**/*.{ts,tsx,css}\" \"mobile-pwa/src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"web/src/**/*.{ts,tsx,css}\" \"mobile-pwa/src/**/*.{ts,tsx,css}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
