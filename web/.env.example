# JNPA UC-III dashboard — build-time configuration (Vite `VITE_*` vars).
# Copy to `.env` (or set via compose) before `make dev-web` / production build.

# Mapbox style token (free tier OK). When set, the Live map uses the Mapbox
# basemap as the PRIMARY provider; when blank it falls back to the Bhuvan (ISRO)
# WMS basemap so the map always renders without a paid key.
VITE_MAPBOX_TOKEN=

# Bhuvan (ISRO) WMS endpoint used as the fallback basemap provider.
VITE_BHUVAN_WMS=https://bhuvan-vec1.nrsc.gov.in/bhuvan/wms

# Gateway base URL used by the Vite dev proxy only (the app itself always calls
# the relative /api path). In the nginx production image nginx proxies /api.
VITE_GATEWAY_URL=http://localhost:8000

# Data source for the dashboard. `mock` (default) runs the full UI from
# deterministic in-app fixtures with ZERO credentials and no backend — so
# `npm run dev` demos instantly. `live` routes every screen through the gateway
# /api surface (the LiveAdapter). The UI never calls camera/Vahan/ULIP/AI APIs
# directly; it only ever talks to the selected adapter.
VITE_DATA_MODE=mock

# Auth gate. When "true" the dashboard renders the login screen, stores the JWT,
# and attaches `Authorization: Bearer <token>` to every /api call. This is a
# COMPILE-TIME flag (Vite inlines it), so it must be set when running the
# production build, NOT just at container runtime. It MUST match the gateway:
# if the gateway runs AUTH_ENABLED=true, build with VITE_AUTH_ENABLED=true or
# every API call returns 401 "missing bearer token". Defaults to false (demo).
VITE_AUTH_ENABLED=false

# ArcGIS Maps SDK basemap key. Optional in dev — the map uses the free
# "dark-gray-vector" basemap without a key. Set for premium basemaps / the
# ArcGIS Enterprise 11.3 production path.
VITE_ARCGIS_API_KEY=
