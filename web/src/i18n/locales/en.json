  "assumptions": {
    "open": "Assumptions & Methodology",
    "title": "Assumptions & Methodology",
    "subtitle": "D.2 sub-criterion 1 — solution approach, synthetic data & simulators",
    "intro": "Production APIs are JNPA-facilitated, post-award. In this PoC each is replaced by a public-schema simulator matching the real wire contract, so swapping mock → live is a configuration change, not a rewrite.",
    "sources": {
      "title": "Production APIs → PoC simulators",
      "body": "Vahan (RC), Sarathi (DL) and FASTag are served by a 25k-plate regex-valid simulator; ICEGATE/TOS by schema-faithful gate & container events; ULIP relay and camera/ANPR streams by clip-replay and mock relays. Live keys drop into .env."
    },
    "synthetic": {
      "title": "Synthetic data",
      "body": "All demand/supply books, gate-data, parking occupancy and telemetry are deterministic synthetic datasets — no Math.random — so every figure is byte-stable across reloads. The 20k-device trucking simulator is hot-scalable to 30k+."
    },
    "dpdp": {
      "title": "DPDP — synthetic faces only",
      "body": "PoC biometrics use synthetic, consented faces only. No real driver biometrics are processed. Real PDP enrollment is a post-award, consent-gated workflow; the PoC proves the verification pipeline (embed → match → PROVISIONAL on miss) on a synthetic gallery."
    },
    "kpi": {
      "title": "KPI baselines",
      "body": "KPI targets/baselines are PoC demonstration defaults (KPI_TARGETS). Production baselines will be set from the JNPA baseline study; % deltas are computed against those baselines."
    },
    "real": {
      "title": "Real in the PoC (not assumed)",
      "body": "The fallback orchestration, the reactive what-if engine (TFC-1/2/3), the cross-twin UC2→UC3 DPD-release event, the KPI arithmetic, geofence violation detection and the police PDF export are all real code, exercised by tests."
    }
  },
